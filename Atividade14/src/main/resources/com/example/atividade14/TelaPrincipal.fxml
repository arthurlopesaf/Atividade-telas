            fx:controller="com.example.atividade14.TelaPrincipalController">
    <children>
        <Label layoutX="58.0" layoutY="24.0" text="Compra de carro novo">
            <font>
                <Font name="System Bold" size="27.0"/>
            </font>
        </Label>
        <Label alignment="CENTER" layoutX="64.0" layoutY="89.0" prefHeight="28.0" prefWidth="272.0"
               text="Deseja comprar um carro novo?">
            <font>
                <Font size="18.0"/>
            </font>
        </Label>
        <RadioButton fx:id="rdbSim" layoutX="92.0" layoutY="127.0" mnemonicParsing="false" text="Sim">
            <toggleGroup>
                <ToggleGroup fx:id="SimNao"/>
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rdbNao" layoutX="267.0" layoutY="127.0" mnemonicParsing="false" text="Não"
