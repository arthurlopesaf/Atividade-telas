                <ToggleGroup fx:id="SimNao2"/>
            </toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rdbNaoDinheiro" layoutX="267.0" layoutY="234.0" mnemonicParsing="false" text="Não"
